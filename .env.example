# ---- Database ----
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/kreatadesigns

# ---- JWT Auth ----
SECRET_KEY=replace-this-with-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Default admin account ----
# Auto-created on first startup if a user with this username doesn't already exist.
# Change these before deploying to production, then log in and keep them safe.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@kreatadesigns.com

# ---- Cloudinary (image storage) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- CORS ----
# URL of your deployed frontend (used in addition to kreatadesigns.com and localhost, which are
# always allowed)
FRONTEND_URL=https://kreatadesigns.com
